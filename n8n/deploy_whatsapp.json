        },
        {
            "parameters": {
                "jsonSchemaExample": {
                    "intencion_compra": "alta",
                    "presupuesto": "500000",
                    "division": "Inmuebles",
                    "tipo_producto": "Villa",
                    "ubicacion": "Costa"
                }
            },
            "id": "3181b716-d2ef-47a8-987b-d87ec8dd204a",
            "name": "Structured Output Parser",
