        },
        {
            "parameters": {
                "promptType": "define",
                "text": "=Analiza el siguiente mensaje de WhatsApp y extrae la información estructurada.\n\nMensaje: {{ $json.body.message }}\n\nExtrae:\n- intencion_compra: (baja/media/alta)\n- presupuesto: (monto numérico o \"no especificado\")\n- division: (Inmuebles/Seguros/Turismo)\n- tipo_producto: (descripción del producto de interés)\n- ubicacion: (ubicación mencionada o \"no especificada\")\n- notas: (observaciones adicionales relevantes)\n\nResponde SOLO con el JSON estructurado, sin texto adicional.",
                "hasOutputParser": true,
                "options": {
                    "systemMessage": "Eres un asistente de análisis de intención de compra para Novo Heritage."
                }
            },
            "id": "2c079ee7-e7fc-4af8-a367-986d9f8bedb2",
            "name": "Extract WhatsApp Intent",
            "type": "@n8n/n8n-nodes-langchain.agent",
            "typeVersion": 3.1,
            "position": [
                464,
                528
            ]
        },
        {
            "parameters": {
                "model": "llama-3.3-70b-versatile",
                "options": {
                    "temperature": 0.3
                }
            },
            "id": "9bb4af6c-6ada-4063-a6c9-4209dd7be616",
            "name": "Groq Model",
            "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
            "typeVersion": 1,
            "position": [
                480,
                752
