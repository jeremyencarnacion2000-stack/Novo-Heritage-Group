        {
            "parameters": {
                "operation": "executeQuery",
                "query": "UPDATE perfil_usuario SET score_interes = COALESCE(score_interes, '{}'::jsonb) || jsonb_build_object(  CASE WHEN $1 LIKE '%Villa%' OR $1 LIKE '%Property%' THEN 'inmuebles' WHEN $1 LIKE '%Insurance%' OR $1 LIKE '%Seguro%' THEN 'seguros' WHEN $1 LIKE '%Hotel%' OR $1 LIKE '%Tour%' THEN 'turismo' ELSE 'general' END, COALESCE((score_interes->>CASE WHEN $1 LIKE '%Villa%' OR $1 LIKE '%Property%' THEN 'inmuebles' WHEN $1 LIKE '%Insurance%' OR $1 LIKE '%Seguro%' THEN 'seguros' WHEN $1 LIKE '%Hotel%' OR $1 LIKE '%Tour%' THEN 'turismo' ELSE 'general' END)::int, 0) + 1 ), ultima_actividad = NOW() WHERE usuario_id = $2",
                "options": {
                    "queryReplacement": "={{ $json.seccion }},{{ $(\"Tracking Webhook\").item.json.body.usuario_id }}"
                }
            },
