      "type": "n8n-nodes-base.facebookGraphApi",
      "typeVersion": 1,
      "position": [1150, 450],
      "credentials": {
        "oAuth2Api": "Instagram"
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "902d293f-366a-4934-be99-4c0cf9e3c97e",
              "leftValue": "={{ $json.content.length }}",
              "rightValue": 10,
              "operator": {
                "type": "number",
