      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM evolution.\"Message\" WHERE \"message\"->>'imageMessage' IS NOT NULL ORDER BY \"messageTimestamp\" DESC LIMIT 1;",
        "options": {}
      },
      "id": "fetch-node",
      "name": "Obtener mensajes",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [
        400,
        400
      ],
      "credentials": {
        "postgres": {
          "id": "ym3KfQZLjCvWmUjS",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ !!($json.message && ($json.message.imageMessage || $json.message.videoMessage)) }}",
              "value2": true
            }
          ]
        },
        "value1": "={{ $node[\"WhatsApp_SQL_Source\"].json.mediaType }}"
      },
      "id": "filter-node",
      "name": "¿Tiene medios?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        600,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://wasa-el6v.onrender.com/chat/getBase64FromMedia",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ instance: $json.instanceId, message: $json.message }) }}",
        "options": {}
      },
      "id": "download-node",
      "name": "Descargar contenido",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        800,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "KwSuSbN8o5BztaZX",
