    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://content.dropboxapi.com/2/files/upload",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Dropbox-API-Arg",
              "value": "={{ JSON.stringify({ \"path\": \"/NovosHeritage/\" + ($json.pushName || \"Media\") + \"/\" + $json.key.id + \".jpg\", \"mode\": \"add\", \"autorename\": true }) }}"
            },
            {
              "name": "Content-Type",
              "value": "application/octet-stream"
            }
          ]
        },
        "sendBody": true,
        "contentType": "binaryData",
        "inputDataFieldName": "data",
        "options": {}
      },
      "id": "dropbox-node",
      "name": "Carga a Dropbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1200,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "KwSuSbN8o5BztaZX",
          "name": "Header Auth account 3"
        }
      },
      "continueOnFail": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.inventario_digital \n  (nombre_proyecto, titulo_profesional, descripcion_limpia, es_constructora_oficial, zona, precio, multimedia)\nVALUES (\n  '{{ JSON.parse($json.choices[0].message.content).nombre }}',\n  '{{ JSON.parse($json.choices[0].message.content).titulo }}',\n  '{{ JSON.parse($json.choices[0].message.content).descripcion }}',\n  {{ JSON.parse($json.choices[0].message.content).es_oficial || false }},\n  '{{ JSON.parse($json.choices[0].message.content).zona }}',\n  '{{ JSON.parse($json.choices[0].message.content).precio }}',\n  '{{ JSON.stringify(($node[\"Carga a Dropbox\"] && $node[\"Carga a Dropbox\"].json && $node[\"Carga a Dropbox\"].json.id) ? [\"https://dl.dropboxusercontent.com/s/\" + $node[\"Carga a Dropbox\"].json.id] : []) }}'::jsonb\n)\nON CONFLICT (nombre_proyecto) DO UPDATE SET\n  multimedia = COALESCE(inventario_digital.multimedia, '[]'::jsonb) || EXCLUDED.multimedia,\n  fecha_actualizacion = NOW();",
        "options": {}
      },
      "id": "db-node",
      "name": "Guardar en Cockroach",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [
        1500,
        400
      ],
      "credentials": {
        "postgres": {
          "id": "Rh6pnnREWkX5ExUN",
          "name": "Postgres account 4"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "\nconst input = $json;\n\n// Check if input is empty or an error object from Axios/Evolution\nif (!input || input.message === 'AxiosError' || input.status === 500) {\n    // If it's an error, we return an empty binary but DON'T stop the workflow\n    // The next node (Dropbox) will fail but we will set 'Continue on Fail' there\n    return {\n        error: \"Media expired or download failed\",\n        skip: true\n    };\n}\n\nlet base64Data = null;\nconst keys = Object.keys(input);\n\nfor (const key of keys) {\n    if (typeof input[key] === 'string' && (input[key].length > 1000 || input[key].includes(';base64,'))) {\n        base64Data = input[key];\n        break;\n    }\n}\n\nif (!base64Data) {\n    return { error: \"No base64 found\", skip: true };\n}\n\nconst cleanBase64 = base64Data.includes(',') ? base64Data.split(',').pop() : base64Data;\n\nreturn {\n  binary: {\n    data: {\n        data: cleanBase64,\n        mimeType: 'image/jpeg',\n        fileName: 'propiedad.jpg'\n    }\n  }\n};"
      },
      "id": "master-converter",
      "name": "Traductor Maestro",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        300
      ],
      "continueOnFail": true
    },
