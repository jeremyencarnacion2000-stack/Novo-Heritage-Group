[
  {
    "name": "search_workflows",
    "description": "Search for workflows with optional filters. Returns a preview of each workflow.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 200,
          "description": "Limit the number of results (max 200)"
        },
        "query": {
          "type": "string",
          "description": "Filter by name or description"
        },
        "projectId": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Search Workflows",
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier of the workflow"
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "The name of the workflow"
              },
              "description": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "The description of the workflow"
              },
              "active": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "Whether the workflow is active"
              },
              "createdAt": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "The ISO timestamp when the workflow was created"
              },
              "updatedAt": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "The ISO timestamp when the workflow was last updated"
              },
              "triggerCount": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "The number of triggers associated with the workflow"
              },
              "scopes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "User permissions for this workflow"
              },
              "canExecute": {
                "type": "boolean",
                "description": "Whether the user has permission to execute this workflow"
              },
              "availableInMCP": {
                "type": "boolean",
                "description": "Whether the workflow is visible to MCP tools"
              }
            },
            "required": [
              "id",
              "name",
              "active",
              "createdAt",
              "updatedAt",
              "triggerCount",
              "scopes",
              "canExecute",
              "availableInMCP"
            ],
            "additionalProperties": false
          },
          "description": "List of workflows matching the query"
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of workflows that match the filters"
        }
      },
      "required": [
        "data",
        "count"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "execute_workflow",
    "description": "Execute a workflow by ID. Returns execution ID and status. To get the full execution results, use the get_execution tool with the returned execution ID. Before executing always ensure you know the input schema by first using the get_workflow_details tool and consulting workflow description",
    "inputSchema": {
      "type": "object",
      "properties": {
        "workflowId": {
          "type": "string",
          "description": "The ID of the workflow to execute"
        },
        "executionMode": {
          "type": "string",
          "enum": [
            "manual",
            "production"
          ],
          "default": "production",
          "description": "Use \"manual\" to test the current version of the workflow. Use \"production\" to execute the published (active) version."
        },
        "inputs": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "chat"
                },
                "chatInput": {
                  "type": "string",
                  "description": "Input for chat-based workflows"
                }
              },
              "required": [
                "type",
                "chatInput"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "form"
                },
                "formData": {
                  "type": "object",
                  "additionalProperties": {},
                  "description": "Input data for form-based workflows"
                }
              },
              "required": [
                "type",
                "formData"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "webhook"
                },
                "webhookData": {
                  "type": "object",
                  "properties": {
                    "method": {
                      "type": "string",
                      "enum": [
                        "GET",
                        "POST",
                        "PUT",
                        "DELETE",
                        "PATCH",
                        "HEAD",
                        "OPTIONS"
                      ],
                      "default": "GET",
                      "description": "HTTP method (defaults to GET)"
                    },
                    "query": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      },
                      "description": "Query string parameters"
                    },
                    "body": {
                      "type": "object",
                      "additionalProperties": {},
                      "description": "Request body data (main webhook payload)"
                    },
                    "headers": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      },
                      "description": "HTTP headers (e.g., authorization, content-type)"
                    }
                  },
                  "additionalProperties": false,
                  "description": "Input data for webhook-based workflows"
                }
              },
              "required": [
                "type",
                "webhookData"
              ],
              "additionalProperties": false
            }
          ],
          "description": "Inputs to provide to the workflow."
        }
      },
      "required": [
        "workflowId"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Execute Workflow",
      "readOnlyHint": false,
      "destructiveHint": true,
      "idempotentHint": true,
      "openWorldHint": true
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "executionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error",
            "running",
            "waiting",
            "canceled",
            "crashed",
            "new",
            "unknown"
          ],
          "description": "The status of the execution"
        },
        "error": {
          "type": "string",
          "description": "Error message if the execution failed"
        }
      },
      "required": [
        "executionId",
        "status"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "get_execution",
    "description": "Get full execution details and results using the execution ID and workflow ID",
    "inputSchema": {
      "type": "object",
      "properties": {
        "workflowId": {
          "type": "string",
          "description": "The ID of the workflow the execution belongs to"
        },
        "executionId": {
          "type": "string",
          "description": "The ID of the execution to retrieve"
        }
      },
      "required": [
        "workflowId",
        "executionId"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Get Execution",
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "execution": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "workflowId": {
                  "type": "string"
                },
                "mode": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "startedAt": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "stoppedAt": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "retryOf": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "retrySuccessId": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "waitTill": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "id",
                "workflowId",
                "mode",
                "status",
                "startedAt",
                "stoppedAt"
              ],
              "additionalProperties": true
            },
            {
              "type": "null"
            }
          ],
          "description": "Execution metadata, or null if an error occurred"
        },
        "data": {
          "description": "Full execution result data"
        },
        "error": {
          "type": "string",
          "description": "Error message if the request failed"
        }
      },
      "required": [
        "execution"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "get_workflow_details",
    "description": "Get detailed information about a specific workflow including trigger details",
    "inputSchema": {
      "type": "object",
      "properties": {
        "workflowId": {
          "type": "string",
          "description": "The ID of the workflow to retrieve"
        }
      },
      "required": [
        "workflowId"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Get Workflow Details",
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "workflow": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "active": {
              "type": "boolean"
            },
            "isArchived": {
              "type": "boolean"
            },
            "versionId": {
              "type": "string",
              "description": "The current workflow version ID"
            },
            "activeVersionId": {
              "type": [
                "string",
                "null"
              ],
              "description": "The active workflow version ID, if available"
            },
            "triggerCount": {
              "type": "number"
            },
            "createdAt": {
              "type": [
                "string",
                "null"
              ]
            },
            "updatedAt": {
              "type": [
                "string",
                "null"
              ]
            },
            "settings": {
              "anyOf": [
                {},
                {
                  "type": "null"
                }
              ]
            },
            "connections": {
              "type": "object",
              "additionalProperties": {}
            },
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "type"
                ],
                "additionalProperties": true
              }
            },
            "activeVersion": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "nodes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/properties/workflow/properties/nodes/items"
                      }
                    },
                    "connections": {
                      "type": "object",
                      "additionalProperties": {}
                    }
                  },
                  "required": [
                    "nodes",
                    "connections"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "null"
                }
              ],
              "description": "Active workflow graph, if available"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "name"
                ],
                "additionalProperties": true
              }
            },
            "meta": {
              "anyOf": [
                {},
                {
                  "type": "null"
                }
              ]
            },
            "parentFolderId": {
              "type": [
                "string",
                "null"
              ]
            },
            "description": {
              "type": "string",
              "description": "The description of the workflow"
            },
            "scopes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "User permissions for this workflow"
            },
            "canExecute": {
              "type": "boolean",
              "description": "Whether the user has permission to execute this workflow"
            }
          },
          "required": [
            "id",
            "name",
            "active",
            "isArchived",
            "versionId",
            "activeVersionId",
            "triggerCount",
            "createdAt",
            "updatedAt",
            "connections",
            "nodes",
            "activeVersion",
            "tags",
            "parentFolderId",
            "scopes",
            "canExecute"
          ],
          "additionalProperties": true,
          "description": "Sanitized workflow data safe for MCP consumption"
        },
        "triggerInfo": {
          "type": "string",
          "description": "Human-readable instructions describing how to trigger the workflow"
        }
      },
      "required": [
        "workflow",
        "triggerInfo"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "publish_workflow",
    "description": "Publish (activate) a workflow to make it available for production execution. This creates an active version from the current draft.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "workflowId": {
          "type": "string",
          "description": "The ID of the workflow to publish"
        },
        "versionId": {
          "type": "string",
          "description": "Optional version ID to publish. If not provided, publishes the current draft version."
        }
      },
      "required": [
        "workflowId"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Publish Workflow",
      "readOnlyHint": false,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "workflowId": {
          "type": "string"
        },
        "activeVersionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "success",
        "workflowId",
        "activeVersionId"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "unpublish_workflow",
    "description": "Unpublish (deactivate) a workflow to stop it from being available for production execution.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "workflowId": {
          "type": "string",
          "description": "The ID of the workflow to unpublish"
        }
      },
      "required": [
        "workflowId"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Unpublish Workflow",
      "readOnlyHint": false,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "workflowId": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "success",
        "workflowId"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "search_nodes",
    "description": "Search for n8n nodes by service name, trigger type, or utility function. Returns node IDs, discriminators (resource/operation/mode), and related nodes needed for get_workflow_node_types.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "queries": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Search queries for n8n nodes ΓÇö service names (e.g. \"gmail\", \"slack\"), trigger types (e.g. \"schedule trigger\", \"webhook\"), or utility nodes (e.g. \"set\", \"if\", \"merge\", \"code\")"
        }
      },
      "required": [
        "queries"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Searching nodes",
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "results": {
          "type": "string",
          "description": "Search results with matching node IDs, discriminators, and related nodes"
        }
      },
      "required": [
        "results"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "get_node_types",
    "description": "Get TypeScript type definitions for n8n nodes. Returns exact parameter names and structures. MUST be called before writing workflow code ΓÇö guessing parameter names creates invalid workflows. Include discriminators (resource/operation/mode) from search results.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "nodeIds": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "nodeId": {
                    "type": "string",
                    "description": "The node type ID (e.g. \"n8n-nodes-base.gmail\")"
                  },
                  "version": {
                    "type": "string",
                    "description": "Specific version (e.g. \"2.1\")"
                  },
                  "resource": {
                    "type": "string",
                    "description": "Resource discriminator (e.g. \"message\")"
                  },
                  "operation": {
                    "type": "string",
                    "description": "Operation discriminator (e.g. \"send\")"
                  },
                  "mode": {
                    "type": "string",
                    "description": "Mode discriminator"
                  }
                },
                "required": [
                  "nodeId"
                ],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 1,
          "description": "Node IDs to get type definitions for. Use plain strings for simple nodes, or objects with discriminators from search results."
        }
      },
      "required": [
        "nodeIds"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Getting node definitions",
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "definitions": {
          "type": "string",
          "description": "TypeScript type definitions for the requested nodes"
        }
      },
      "required": [
        "definitions"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "get_suggested_nodes",
    "description": "Get curated node recommendations for workflow technique categories. Returns recommended nodes with pattern hints and configuration guidance. Use after analyzing what kind of workflow to build.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Workflow technique categories. Available: chatbot, notification, scheduling, data_transformation, data_persistence, data_extraction, document_processing, form_input, content_generation, triage, scraping_and_research"
        }
      },
      "required": [
        "categories"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Getting suggested nodes",
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "suggestions": {
          "type": "string",
          "description": "Curated node recommendations with pattern hints and configuration guidance"
        }
      },
      "required": [
        "suggestions"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "validate_workflow",
    "description": "Validate n8n Workflow SDK code. Parses the code into a workflow and checks for errors. Returns the workflow JSON if valid, or detailed error messages to fix. Always validate before creating a workflow.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Full TypeScript/JavaScript workflow code using the n8n Workflow SDK. Must include the workflow export."
        }
      },
      "required": [
        "code"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "title": "Validating workflow",
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "valid": {
          "type": "boolean",
          "description": "Whether the workflow code is valid"
        },
        "nodeCount": {
          "type": "number",
          "description": "The number of nodes in the workflow (if valid)"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "The warning code identifying the type of warning"
              },
              "message": {
                "type": "string",
                "description": "The warning message"
              },
              "nodeName": {
                "type": "string",
                "description": "The node that triggered the warning"
              },
              "parameterPath": {
                "type": "string",
                "description": "The parameter path that triggered the warning"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "additionalProperties": false
          },
          "description": "Validation warnings (if any)"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Validation errors (if invalid)"
        }
      },
      "required": [
        "valid"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  },
  {
    "name": "create_workflow_from_code",
    "description": "Create a workflow in n8n from validated SDK code. Parses the code into a workflow and saves it. Always validate with validate_workflow first.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Full TypeScript/JavaScript workflow code using the n8n Workflow SDK. Must be validated first with validate_workflow."
        },
        "name": {
